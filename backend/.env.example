# KanjiVision AI backend — environment
NODE_ENV=development
PORT=3001

# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/kanjivision?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kanjivision?schema=public"

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000,https://kanjivision.app

# --- Payments ---
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PUBLIC_KEY=
PADDLE_WEBHOOK_SECRET=
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# --- AI (shared across Vision Platform services) ---
ANTHROPIC_API_KEY=
# Override Claude model (defaults to claude-sonnet-4-6). Use claude-opus-4-6
# for higher quality at higher cost.
CLAUDE_MODEL=
STABILITY_API_KEY=

# --- Internal admin API ---
# Shared secret that gates POST /api/internal/generate-words{,-batch}.
# Keep out of client code — only server-to-server calls should hold this.
INTERNAL_API_KEY=

# --- Email ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@kanjivision.app

# --- Supabase storage (optional) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
