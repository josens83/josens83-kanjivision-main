# KanjiVision AI backend — environment
NODE_ENV=development
PORT=3001

# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/kanjivision?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kanjivision?schema=public"

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override — defaults to {origin}/api/auth/callback/google
# GOOGLE_REDIRECT_URI=
# Frontend origin for the post-OAuth redirect (defaults to req.headers.origin)
# FRONTEND_URL=https://josens83-kanjivision-main.vercel.app

# --- CORS ---
CORS_ORIGIN=http://localhost:3000,https://kanjivision.app

# --- Payments ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_BASIC_MONTHLY=
PADDLE_PRICE_ID_BASIC_YEARLY=
PADDLE_PRICE_ID_PREMIUM_MONTHLY=
PADDLE_PRICE_ID_PREMIUM_YEARLY=
PADDLE_PUBLIC_KEY=
PADDLE_WEBHOOK_SECRET=
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# --- AI (shared across Vision Platform services) ---
ANTHROPIC_API_KEY=
# Override Claude model (defaults to claude-sonnet-4-6). Use claude-opus-4-6
# for higher quality at higher cost.
CLAUDE_MODEL=
STABILITY_API_KEY=

# --- Internal admin API ---
# Shared secret that gates POST /api/internal/generate-words{,-batch}.
# Keep out of client code — only server-to-server calls should hold this.
INTERNAL_API_KEY=

# --- Email ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@kanjivision.app

# --- Supabase storage (for mnemonic images) ---
# Used by image.service.ts to upload generated PNGs to the
# kanji-mnemonics bucket. Create the bucket in the Supabase dashboard
# with public access enabled.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
