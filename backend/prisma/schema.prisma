// KanjiVision AI — Prisma schema
// Structure mirrors Vision Platform services (VocaVision / HangeulVision / KanjiVision).
// Only ExamCategory differs: JLPT levels + THEME + GENERAL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ExamCategory {
  JLPT_N5
  JLPT_N4
  JLPT_N3
  JLPT_N2
  JLPT_N1
  THEME
  GENERAL
}

enum WordType {
  KANGO      // 漢語 (Sino-Japanese)
  WAGO       // 和語 (native Japanese)
  GAIRAIGO   // 外来語 (loanwords)
}

enum UserTier {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum PaymentProcessor {
  PADDLE
  TOSS
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ---------- Users ----------

model User {
  id             String         @id @default(cuid())
  email           String         @unique
  passwordHash    String?
  displayName     String?
  provider        String         @default("email")
  googleId        String?        @unique
  locale          String         @default("en")
  tier            UserTier       @default(FREE)
  dailyGoal        Int            @default(20)
  dailyProgress    Int            @default(0)
  lastGoalReset    DateTime?
  subscriptionPlan String?
  subscriptionStatus String?
  subscriptionEnd  DateTime?
  paddleSubscriptionId String?
  autoRenewal      Boolean        @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  recommendedLevel String?
  emailVerifiedAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions  Subscription[]
  payments       Payment[]
  progress       Progress[]
  sessions       StudySession[]
  mnemonicImages MnemonicImage[]
  bookmarks      Bookmark[]
  achievements   UserAchievement[]
  notifications  Notification[]
  supportTickets SupportTicket[]
  leagues        LeagueMembership[]
  decks          Deck[]
  replies        Reply[]
  purchases      UserPurchase[]

  @@index([email])
}

// ---------- Vocabulary content ----------

model Word {
  id             String         @id @default(cuid())
  lemma          String         // 学校
  reading        String         // がっこう
  meaning        String         // school
  partOfSpeech   String
  examCategory   ExamCategory
  type           WordType       @default(WAGO)
  category       String?        // "greeting" | "food" | "place" | "time" | "family" | "verb"
  tierRequired   UserTier       @default(FREE)
  mnemonic       String?
  examples       Json?          // [{jp,reading,en}, ...]
  collocations   String[]       @default([])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  kanjiParts      KanjiPart[]
  progress        Progress[]
  mnemonicImages  MnemonicImage[]
  bookmarks       Bookmark[]
  productPackages ProductPackageWord[]

  @@index([examCategory])
  @@index([tierRequired])
  @@index([category])
  @@unique([lemma, reading])
}

model KanjiPart {
  id        String   @id @default(cuid())
  wordId    String
  position  Int
  char      String   // e.g. "学"
  reading   String   // e.g. "ガク" or "まなぶ"
  meaning   String   // e.g. "learn"
  onyomi    String[] @default([])
  kunyomi   String[] @default([])
  createdAt DateTime @default(now())

  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@index([char])
}

// ---------- Achievements ----------

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  icon        String
  condition   String
  threshold   Int      @default(1)
  createdAt   DateTime @default(now())

  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ---------- Bookmarks ----------

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  wordId    String
  notes     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
}

// ---------- Study / SRS ----------

model Progress {
  id             String   @id @default(cuid())
  userId         String
  wordId         String
  repetition     Int      @default(0)
  interval       Int      @default(0)
  easiness       Float    @default(2.5)
  dueAt          DateTime @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word           Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, dueAt])
}

model StudySession {
  id          String       @id @default(cuid())
  userId      String
  examCategory ExamCategory
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  cardsSeen   Int          @default(0)
  cardsCorrect Int         @default(0)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ---------- AI-generated imagery ----------

model MnemonicImage {
  id         String   @id @default(cuid())
  wordId     String
  userId     String?
  prompt     String
  url        String
  provider   String   @default("stability")
  createdAt  DateTime @default(now())

  word       Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([wordId])
}

// ---------- Replies ----------

model Reply {
  id              String       @id @default(cuid())
  userId          String
  announcementId  String
  body            String
  status          String       @default("PENDING")
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([announcementId])
}

// ---------- Collections ----------

model Collection {
  id           String   @id @default(cuid())
  name         String
  description  String?
  icon         String?
  wordIds      String[] @default([])
  isPublic     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

// ---------- Announcements ----------

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String    @default("INFO")
  audience    String    @default("ALL")
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  replies     Reply[]
}

// ---------- Leagues ----------

model League {
  id        String   @id @default(cuid())
  tier      String
  weekStart DateTime
  weekEnd   DateTime
  createdAt DateTime @default(now())
  members   LeagueMembership[]
  @@unique([tier, weekStart])
}

model LeagueMembership {
  id       String  @id @default(cuid())
  userId   String
  leagueId String
  xp       Int     @default(0)
  result   String?
  createdAt DateTime @default(now())
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  league   League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  @@unique([userId, leagueId])
  @@index([leagueId])
}

// ---------- Custom Decks ----------

model Deck {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  wordIds     String[] @default([])
  isPublic    Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// ---------- Notifications ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ---------- Support ----------

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  name      String?
  category  String
  subject   String
  message   String
  status    String   @default("OPEN")
  priority  String   @default("NORMAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

// ---------- Product Packages (Standalone Packs) ----------

model ProductPackage {
  id              String   @id @default(cuid())
  name            String
  nameEn          String?
  slug            String   @unique
  description     String?
  descriptionEn   String?
  shortDesc       String?
  shortDescEn     String?
  exam            String?
  price           Int      @default(0)
  priceGlobal     Decimal? @db.Decimal(10, 2)
  originalPrice   Int?
  durationDays    Int      @default(180)
  badge           String?
  badgeColor      String?
  imageUrl        String?
  isActive        Boolean  @default(true)
  isComingSoon    Boolean  @default(false)
  displayOrder    Int      @default(0)
  paddlePriceId   String?
  paddleProductId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  words           ProductPackageWord[]
  purchases       UserPurchase[]
}

model ProductPackageWord {
  id           String         @id @default(cuid())
  packageId    String
  wordId       String
  displayOrder Int            @default(0)

  package      ProductPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  word         Word           @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([packageId, wordId])
}

model UserPurchase {
  id        String         @id @default(cuid())
  userId    String
  packageId String
  amount    Int            @default(0)
  status    String         @default("ACTIVE")
  expiresAt DateTime?
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  package   ProductPackage @relation(fields: [packageId], references: [id])

  @@index([userId])
}

// ---------- Billing ----------

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  processor       PaymentProcessor
  externalId      String             @unique
  plan            String
  status          SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  canceledAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id          String           @id @default(cuid())
  userId      String
  processor   PaymentProcessor
  externalId  String           @unique
  amountCents Int
  currency    String           @default("USD")
  status      PaymentStatus    @default(PENDING)
  rawEvent    Json?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
